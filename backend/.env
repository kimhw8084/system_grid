# API Configuration
PROJECT_NAME="SYSGRID Production API"
API_V1_STR="/api/v1"
API_ENDPOINT="http://localhost:8000"
PORT=8000

# Environment: development, production, test
ENVIRONMENT=development

# CORS Configuration
BACKEND_CORS_ORIGINS=["*"]

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./system_grid.db

# Storage & Infrastructure
STORAGE_ROOT="./storage"
IMAGE_PATH="./storage/images"
BACKUP_PATH="./backups"
SCRIPTS_PATH="./scripts"
USER_POOL_PATH="./storage/user_pool.json"
VENV_PATH="./venv"
LOG_LEVEL="INFO"

# Execution & Hot Reload
HOT_RELOAD_ENABLED=true
UI_DEBUG_LOGGING=false
UI_TIMEOUT=30000
FEATURE_FLAGS="{}"
AUTH_SECRET="change-me-immediately"
SESSION_EXPIRY=1440

# Backend Management
MAX_UPLOAD_SIZE=50
WORKER_COUNT=4
CACHE_TTL=3600
SMTP_HOST="localhost"
SMTP_PORT=1025
ALERT_EMAIL="admin@sysgrid.local"
ENABLE_AUDIT_LOGS=true
DB_BACKUP_SCHEDULE="0 0 * * *"
TOKEN_ALGORITHM="HS256"
REQUEST_TIMEOUT=60
