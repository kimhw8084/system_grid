# SYSGRID Backend Configuration Example

# API Configuration
PROJECT_NAME="SYSGRID Production API"
API_V1_STR="/api/v1"

# Environment: development, production, test
ENVIRONMENT=development

# CORS Configuration
# JSON array string of allowed frontend origins
# Example: ["http://127.0.0.1:5173","https://sysgrid.company.com"]
BACKEND_CORS_ORIGINS=["*"]

# Bootstrap Identity
# Use an explicit development/bootstrap user so tenant routing does not fall back to admin_root.
DEFAULT_USER_ID="haewon.kim"
AUTO_ADMIN_USER_IDS="haewon.kim"
# Name of the backend environment variable that carries the effective user id.
# Example for company deployments: USER_ID_ENV_VAR="AccessKey"
USER_ID_ENV_VAR="USER_ID"

# Public Read-Only Access
# When enabled, any user can browse the app against the public tenant on safe read methods.
PUBLIC_READONLY_ENABLED=true
PUBLIC_READONLY_TENANT_NAME="Default Engine"

# Database Configuration
# For SQLite: sqlite+aiosqlite:///./system_grid.db
# For PostgreSQL: postgresql+asyncpg://user:pass@localhost/dbname
DATABASE_URL=sqlite+aiosqlite:///./system_grid.db

# Advanced Modular Flags (Managed via DB / Settings UI)
# These flags are dynamically loaded and managed from the UI settings surface.
# You can set initial bootstrap values here.

# Backend Service Controls
PORT=8000
LOG_LEVEL=INFO
WORKER_COUNT=4
CACHE_TTL=300
REQUEST_TIMEOUT=30
HOT_RELOAD_ENABLED=false
ENABLE_AUDIT_LOGS=true
DB_BACKUP_SCHEDULE="0 2 * * *"
TOKEN_ALGORITHM=HS256

# Storage & Paths
STORAGE_ROOT=./storage
IMAGE_PATH=./storage/images
MAX_UPLOAD_SIZE=50

# Alerting
SMTP_HOST=localhost
SMTP_PORT=2525
ALERT_EMAIL=alerts@sysgrid.local
