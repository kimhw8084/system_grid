# SYSGRID Backend Configuration Example

# API Configuration
PROJECT_NAME="SYSGRID Production API"
API_V1_STR="/api/v1"

# Environment: development, production, test
ENVIRONMENT=development

# CORS Configuration
# JSON array string of allowed frontend origins
# Example: ["http://127.0.0.1:5173","https://sysgrid.company.com"]
BACKEND_CORS_ORIGINS=["*"]

# Database Configuration
# For SQLite: sqlite+aiosqlite:///./system_grid.db
# For PostgreSQL: postgresql+asyncpg://user:pass@localhost/dbname
DATABASE_URL=sqlite+aiosqlite:///./system_grid.db

# Advanced Modular Flags (Managed via DB / Settings UI)
# These flags are dynamically loaded and managed from the UI settings surface.
# You can set initial bootstrap values here.

# Backend Service Controls
PORT=8000
LOG_LEVEL=INFO
WORKER_COUNT=4
CACHE_TTL=300
REQUEST_TIMEOUT=30
HOT_RELOAD_ENABLED=false
ENABLE_AUDIT_LOGS=true
DB_BACKUP_SCHEDULE="0 2 * * *"
TOKEN_ALGORITHM=HS256

# Storage & Paths
STORAGE_ROOT=./storage
IMAGE_PATH=./storage/images
MAX_UPLOAD_SIZE=50

# Alerting
SMTP_HOST=localhost
SMTP_PORT=2525
ALERT_EMAIL=alerts@sysgrid.local
