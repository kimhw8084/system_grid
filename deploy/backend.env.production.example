ENVIRONMENT=production
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=https://sysgrid.example.com
ALLOWED_HOSTS=sysgrid-api.example.com
IDENTITY_MODE=trusted_proxy
TRUSTED_PROXY_USER_HEADER=X-Authenticated-User
DATABASE_URL=sqlite+aiosqlite:////var/lib/sysgrid/default/system_grid.db
CONFIG_DATABASE_URL=sqlite+aiosqlite:////var/lib/sysgrid/config/config.db
TENANT_STORAGE_ROOT=/var/lib/sysgrid/tenants
PUBLIC_READONLY_ENABLED=false
ALLOW_PUBLIC_READONLY_IN_PRODUCTION=false
DEFAULT_USER_ID=sysgrid-service
AUTO_ADMIN_USER_IDS=
ALLOW_AUTO_ADMIN_IN_PRODUCTION=false
