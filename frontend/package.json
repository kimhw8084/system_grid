{
  "name": "system-grid-frontend",
  "private": true,
  "version": "1.2.4",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "check:operational-registry-drift": "node scripts/check-operational-registry-drift.cjs",
    "check:form-contracts": "node scripts/check-form-contracts.cjs",
    "check:row-action-contracts": "node scripts/check-row-action-contracts.cjs",
    "check:shell-contracts": "node scripts/check-shell-contracts.cjs",
    "check:operational-contracts": "npm run check:operational-registry-drift && npm run check:form-contracts && npm run check:row-action-contracts && npm run check:shell-contracts",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:assets": "playwright test tests/assets-workflows.spec.ts",
    "test:lint": "node test_linter.cjs",
    "verify:app": "sh -c 'cd .. && ./scripts/verify-app.sh'",
    "test:e2e:release": "playwright test --config=playwright.release.config.ts --workers=1",
    "test:e2e:chaos": "playwright test --config=playwright.chaos.config.ts",
    "test:e2e:evidence": "playwright test --config=playwright.evidence.config.ts --workers=1"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/view": "^6.43.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.0.0",
    "@uiw/react-codemirror": "^4.25.10",
    "ag-grid-community": "^31.3.4",
    "ag-grid-react": "^31.3.4",
    "clsx": "^2.1.0",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.29.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.22.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.0",
    "tailwind-merge": "^2.2.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dagre": "^0.7.54",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.17",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
