# SYSGRID Frontend Configuration Example

# Base URL for the backend API
# If serving UI and API together or using proxy, you can leave this empty.
# Example: http://127.0.0.1:8000, https://api.sysgrid.com
VITE_API_BASE_URL=

# Port for local dev server
VITE_PORT=5173
VITE_BACKEND_PORT=8000
VITE_BACKEND_HOST=127.0.0.1

# Application Identity & Branding
# These are fallback bootstrap values, dynamic configuration is stored in the backend DB and fetched on startup.
VITE_APP_NAME="SYSGRID INFRASTRUCTURE"
VITE_APP_TITLE="SYSGRID INFRASTRUCTURE"
VITE_APP_VERSION="1.2.4"

# Advanced UI Controls
VITE_UI_TIMEOUT=30000
VITE_UI_DEBUG_LOGGING=false
VITE_POLLING_INTERVAL=30000
VITE_ENABLE_ANALYTICS=false
VITE_MAX_GRID_ROWS=1000
VITE_THEME_DEFAULT=nordic-frost-v1
VITE_MAINTENANCE_MODE=false
VITE_SUPPORT_URL="https://support.sysgrid.local"
VITE_AUTO_LOGOUT_IDLE=3600
VITE_TOAST_DURATION=4000
VITE_ENABLE_WEBSOCKETS=true
