# SYSGRID Frontend Configuration Example
# Copy this to .env and adjust as needed

# Base URL for the backend API (e.g., http://localhost:8000, https://api.sysgrid.com)
# For local dev with vite proxy, you can leave it empty if proxying /api
VITE_API_BASE_URL=http://127.0.0.1:8000

# Application Identity
VITE_APP_NAME="SYSGRID INFRASTRUCTURE"
VITE_APP_VERSION="1.2.4"
